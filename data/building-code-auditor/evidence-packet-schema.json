{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/building-code-auditor/evidence-packet.schema.json",
  "title": "Earthquake Evidence Packet",
  "description": "Gate 3 packet schema for earthquake-related public evidence gathered after Gate 1 place lock and Gate 2 audit scope lock.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workflow_step",
    "confirmed_place",
    "locked_scope",
    "target_context",
    "lane_results",
    "integrated_answer",
    "manual_follow_up",
    "overclaim_boundary",
    "validation_summary"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "workflow_step": {
      "type": "string",
      "const": "earthquake_evidence_packet"
    },
    "confirmed_place": {
      "type": "object"
    },
    "locked_scope": {
      "type": "object"
    },
    "target_context": {
      "type": "object",
      "required": [
        "target_subscope",
        "timeframe",
        "earthquake_event",
        "jurisdiction",
        "identity_caveats"
      ]
    },
    "lane_results": {
      "type": "array",
      "minItems": 1
    },
    "integrated_answer": {
      "type": "object"
    },
    "manual_follow_up": {
      "type": "object"
    },
    "overclaim_boundary": {
      "type": "object"
    },
    "validation_summary": {
      "type": "object"
    }
  }
}
