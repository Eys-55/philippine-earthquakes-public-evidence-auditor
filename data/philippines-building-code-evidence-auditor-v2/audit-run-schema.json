{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "2.1.0",
  "title": "Philippines Earthquake Public Evidence Auditor Parent Audit Run",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workflow_step",
    "confirmed_building",
    "selected_earthquake_lanes",
    "source_ingestion_policy",
    "lane_packets",
    "overall_summary",
    "unresolved_cross_lane_exceptions",
    "final_overclaim_status"
  ],
  "properties": {
    "schema_version": {
      "const": "2.1.0"
    },
    "workflow_step": {
      "const": "earthquake_public_evidence_audit_run"
    },
    "confirmed_building": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "display_name",
        "candidate_id",
        "city",
        "country",
        "gate_1_status",
        "identity_confirmation_sources"
      ],
      "properties": {
        "display_name": {"type": "string"},
        "candidate_id": {"type": "string"},
        "city": {"type": "string"},
        "country": {"const": "Philippines"},
        "gate_1_status": {"const": "confirmed_by_user"},
        "identity_confirmation_sources": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "url", "use"],
            "properties": {
              "label": {"type": "string"},
              "url": {"type": "string", "format": "uri"},
              "use": {"type": "string"}
            }
          }
        }
      }
    },
    "selected_earthquake_lanes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "nscp_seismic_design_evidence",
          "obo_structural_permit_review_evidence",
          "post_earthquake_tag_status",
          "clearance_after_damage_or_tag"
        ]
      }
    },
    "source_ingestion_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "stored_fields", "full_page_archive"],
      "properties": {
        "mode": {"const": "metadata_plus_short_snippets"},
        "stored_fields": {
          "type": "array",
          "items": {"type": "string"}
        },
        "full_page_archive": {"const": false}
      }
    },
    "lane_packets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "lane_id",
          "packet_ref",
          "packet_result_status",
          "summary",
          "overclaim_status",
          "requires_manual_request"
        ],
        "properties": {
          "lane_id": {
            "type": "string",
            "enum": [
              "nscp_seismic_design_evidence",
              "obo_structural_permit_review_evidence",
              "post_earthquake_tag_status",
              "clearance_after_damage_or_tag"
            ]
          },
          "packet_ref": {"type": "string"},
          "packet_result_status": {
            "type": "string",
            "enum": [
              "no_public_evidence_found",
              "no_public_answer_found",
              "positive_evidence_found",
              "weak_lead_only"
            ]
          },
          "summary": {"type": "string"},
          "overclaim_status": {
            "type": "string",
            "enum": ["passed", "blocked_for_revision"]
          },
          "requires_manual_request": {"type": "boolean"}
        }
      }
    },
    "overall_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "source_bounded_summary", "forbidden_conclusion_codes"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["ready_for_operator_use", "blocked_for_revision"]
        },
        "source_bounded_summary": {"type": "string"},
        "forbidden_conclusion_codes": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "unresolved_cross_lane_exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["exception_id", "description", "resolution_route"],
        "properties": {
          "exception_id": {"type": "string"},
          "description": {"type": "string"},
          "resolution_route": {"type": "string"}
        }
      }
    },
    "final_overclaim_status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "checked_lane_ids", "checklist"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["passed", "blocked_for_revision"]
        },
        "checked_lane_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "nscp_seismic_design_evidence",
              "obo_structural_permit_review_evidence",
              "post_earthquake_tag_status",
              "clearance_after_damage_or_tag"
            ]
          }
        },
        "checklist": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "exact_building_match_confirmed",
            "each_lane_packet_audited",
            "parent_summary_audited",
            "missing_evidence_not_converted_to_conclusion",
            "unresolved_exceptions_preserved"
          ],
          "properties": {
            "exact_building_match_confirmed": {"type": "boolean"},
            "each_lane_packet_audited": {"type": "boolean"},
            "parent_summary_audited": {"type": "boolean"},
            "missing_evidence_not_converted_to_conclusion": {"type": "boolean"},
            "unresolved_exceptions_preserved": {"type": "boolean"}
          }
        }
      }
    }
  }
}
