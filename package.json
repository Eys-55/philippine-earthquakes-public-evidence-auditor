{
  "name": "market-research-agent-control",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare:tracker-ui": "node scripts/control-repo.mjs export-tracker-ui-data",
    "test": "node --test tests/*.test.mjs",
    "validate": "node scripts/control-repo.mjs validate-all",
    "tracker:status": "node scripts/control-repo.mjs tracker-status",
    "tracker:upload-gate": "node scripts/control-repo.mjs tracker-upload-gate",
    "dev": "npm run prepare:tracker-ui && astro dev",
    "build": "npm run prepare:tracker-ui && astro build",
    "preview": "astro preview"
  },
  "devDependencies": {
    "astro": "^6.3.1"
  }
}
